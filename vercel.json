{
  "version": 2,
  "builds": [
    {
      "src": "index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.ts"
    }
  ],
  "functions": {
    "index.ts": {
      "includeFiles": [
        "src/config.json",
        "public/**",
        "router/**"
      ]
    }
  }
}
